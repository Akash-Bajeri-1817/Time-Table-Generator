<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
	<session-factory>
		<!-- Database Connection Settings -->
		<property name="connection.driver_class">org.postgresql.Driver</property>
		<property name="connection.url">jdbc:postgresql://localhost:5432/timetable_db</property>
		<property name="connection.username">root</property>
		<property name="connection.password">root</property>

		<!-- JDBC Connection Pool (using default Hibernate pool for simplicity) -->
		<property name="connection.pool_size">10</property>

		<!-- SQL Dialect -->
		<property name="dialect">org.hibernate.dialect.PostgreSQLDialect</property>

		<!-- Echo all executed SQL to stdout -->
		<property name="show_sql">true</property>
		<property name="format_sql">true</property>

		<!-- Auto-generation of tables (update schema on startup) -->
		<property name="hbm2ddl.auto">update</property>

		<!-- Current Session Context -->
		<property name="current_session_context_class">thread</property>

		<!-- Mapping Entities (Will be added as we create them) -->
		<mapping class="com.timetable.model.Faculty" />
		<mapping class="com.timetable.model.Subject" />
		<mapping class="com.timetable.model.Room" />
		<mapping class="com.timetable.model.StudentGroup" />
		<mapping class="com.timetable.model.TimeSlot" />
		<mapping class="com.timetable.model.Workload" />
		<mapping class="com.timetable.model.Schedule" />
		<mapping class="com.timetable.model.Branch" />
		<mapping class="com.timetable.model.Division" />
		<mapping class="com.timetable.model.Batch" />
		<mapping class="com.timetable.model.TimetableConfig" />
	</session-factory>
</hibernate-configuration>
